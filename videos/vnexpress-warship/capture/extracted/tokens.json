  "headings": [
    {
      "level": 1,
      "text": "Chiến hạm Mỹ nã pháo, bắt tàu hàng Iran",
      "fontSize": "32px",
      "fontWeight": "700",
      "color": "#222222"
    },
    {
      "level": 2,
      "text": "Chiến hạm Mỹ nã pháo, bắt tàu hàng Iran",
      "fontSize": "14px",
      "fontWeight": "700",
      "color": "#202020"
    },
    {
      "level": 4,
      "text": "Ông Trump tiếp tục dọa 'phá hủy mọi cây cầu, nhà máy điện' ở Iran",
      "fontSize": "15px",
      "fontWeight": "700",
      "color": "#222222"
    },
    {
      "level": 4,
      "text": "Iran bổ sung bệ phóng tên lửa 'nhanh hơn trước chiến sự'",
      "fontSize": "15px",
      "fontWeight": "700",
      "color": "#222222"
    },
    {
      "level": 4,
      "text": "Ngày hỗn loạn ở eo biển Hormuz",
      "fontSize": "15px",
      "fontWeight": "700",
      "color": "#222222"
    },
    {
      "level": 2,
      "text": "Xung đột Trung Đông",
      "fontSize": "15px",
      "fontWeight": "700",
      "color": "#9F224E"
    },
    {
      "level": 4,
      "text": "Vingroup sắp ra mắt 'Siêu dự án' 6.206 ha tại vịnh Hạ Long",
      "fontSize": "15px",
      "fontWeight": "700",
      "color": "#222222"
    },
    {
      "level": 4,
      "text": "Ra mắt 2 tòa căn hộ hạng sang cuối cùng tại Vinhomes Cổ Loa",
      "fontSize": "15px",
      "fontWeight": "700",
      "color": "#222222"
    },
    {
      "level": 3,
      "text": "Ý kiến",
      "fontSize": "20px",
      "fontWeight": "700",
      "color": "#222222"
    },
    {
      "level": 3,
      "text": "Tags:",
      "fontSize": "15px",
      "fontWeight": "400",
      "color": "#BDBDBD"
    },
    {
      "level": 4,
      "text": "Mỹ",
      "fontSize": "15px",
      "fontWeight": "400",
      "color": "#222222"
    },
    {
      "level": 4,
      "text": "Iran",
      "fontSize": "15px",
      "fontWeight": "400",
      "color": "#222222"
    },
    {
      "level": 4,
      "text": "Donald Trump",
      "fontSize": "15px",
      "fontWeight": "400",
      "color": "#222222"
    },
    {
      "level": 4,
      "text": "khu trục hạm Mỹ",
      "fontSize": "15px",
      "fontWeight": "400",
      "color": "#222222"
    },
    {
      "level": 4,
      "text": "cảng Iran",
      "fontSize": "15px",
      "fontWeight": "400",
      "color": "#222222"
    },
    {
      "level": 3,
      "text": "Thế giới",
      "fontSize": "18px",
      "fontWeight": "700",
      "color": "#222222"
    },
    {
      "level": 4,
      "text": "Iran 'không có kế hoạch tiếp tục đàm phán với Mỹ'",
      "fontSize": "18px",
      "fontWeight": "700",
      "color": "#222222"
    },
    {
      "level": 4,
      "text": "Xả súng tại Mỹ, 8 trẻ em thiệt mạng",
      "fontSize": "18px",
      "fontWeight": "700",
      "color": "#222222"
    },
    {
      "level": 4,
      "text": "Nỗi bất an của đảng Cộng hòa về chiến sự Iran",
      "fontSize": "18px",
      "fontWeight": "700",
      "color": "#222222"
    },
    {
      "level": 4,
      "text": "Nạn đục trộm bình xăng ở Mỹ khi giá nhiên liệu tăng",
      "fontSize": "18px",
      "fontWeight": "700",
      "color": "#222222"
    }
  ],
